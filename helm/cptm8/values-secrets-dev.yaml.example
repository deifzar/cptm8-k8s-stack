# =============================================================================
# CPTM8 Helm Chart - Development Secrets
# =============================================================================
# This file contains sensitive values for local Kind development deployment.
#
# INSTRUCTIONS:
#   1. Copy this file: cp values-secrets-dev.yaml.example values-secrets-dev.yaml
#   2. Fill in the placeholder values (or use defaults for local dev)
#   3. Use with Helm: helm install cptm8 helm/cptm8 -f values-secrets-dev.yaml
#
# For local development, you can use simple passwords.
# These should NEVER be used in staging or production!
#
# =============================================================================

# =============================================================================
# GLOBAL VALUES - Passed to ALL subcharts (including opensearch)
# =============================================================================
global:
  opensearch:
    # Note: OpenSearch requires bcrypt hashes for internal users.
    # Generate bcrypt hashes using:
    #   python3 -c "import bcrypt; print(bcrypt.hashpw(b'your-password', bcrypt.gensalt(rounds=12)).decode())"
    # Or using mkpasswd
    #     mkpasswd -m bcrypt -R 12 'your-password'
    # Or using Docker:
    #   docker run -it --rm opensearchproject/opensearch:2.11.1 \
    #     /usr/share/opensearch/plugins/opensearch-security/tools/hash.sh -p your-password
    adminHash: "$2a$..."
    kibanaserverHash: "$2a$..."

secrets:
  method: inline

  data:
    # =========================================================================
    # PostgreSQL Secrets
    # =========================================================================
    postgresql:
      rootPassword: "devroot123"
      userPassword: "devuser123"
      databaseUrl: ""  # Auto-generated

    # =========================================================================
    # MongoDB Secrets
    # =========================================================================
    mongodb:
      rootPassword: "devroot123"
      userPassword: "devuser123"
      databaseUrl: ""  # Auto-generated

    # =========================================================================
    # RabbitMQ Secrets
    # =========================================================================
    rabbitmq:
      username: "cptm8user"
      password: "devrabbit123"
      url: ""  # Auto-generated

    # =========================================================================
    # OpenSearch Secrets
    # =========================================================================
    opensearch:
      adminPassword: "DevAdmin123!"

    # =========================================================================
    # Application Secrets (NextAuth/AuthJS)
    # =========================================================================
    application:
      # For dev, you can use a simple secret
      # Generate with: openssl rand -base64 32
      authSecret: "dev-secret-change-in-production-must-be-32-chars-minimum"

    # =========================================================================
    # SMTP Secrets (Optional for dev)
    # =========================================================================
    smtp:
      # Leave empty if not testing email functionality
      username: ""
      password: ""

    # =========================================================================
    # AWS Secrets (Optional for dev)
    # =========================================================================
    aws:
      # Only needed if testing S3 uploads locally
      s3AccessKey: ""
      s3SecretKey: ""
      # Only needed if pulling from ECR
      ecrAccessKeyId: ""
      ecrSecretAccessKey: ""

    # =========================================================================
    # Google OAuth Secrets (Optional for dev)
    # =========================================================================
    google:
      # Only needed if testing Google OAuth locally
      # You can create a separate OAuth app for localhost
      clientId: ""
      clientSecret: ""

# =============================================================================
# USAGE
# =============================================================================
#
# Option 1: Use with default values.yaml
#   helm install cptm8 helm/cptm8 -n cptm8-dev --create-namespace \
#     -f helm/cptm8/values-secrets-dev.yaml
#
# Option 2: Let Helm auto-generate passwords (empty values)
#   helm install cptm8 helm/cptm8 -n cptm8-dev --create-namespace
#
# =============================================================================