# =============================================================================
# CPTM8 Helm Chart - AWS Staging Secrets
# =============================================================================
# This file contains sensitive values for AWS EKS staging deployment.
#
# INSTRUCTIONS:
#   1. Copy this file: cp values-secrets-staging-aws.yaml.example values-secrets-staging-aws.yaml
#   2. Fill in all the placeholder values with actual secrets
#   3. Encrypt with SOPS: sops -e -i values-secrets-staging-aws.yaml
#   4. Use with Helm: helm install cptm8 helm/cptm8 -f values-staging-aws.yaml -f <(sops -d values-secrets-staging-aws.yaml)
#
# SOPS SETUP (first time):
#   # Generate age key
#   age-keygen -o ~/.sops/age-key.txt
#
#   # Create .sops.yaml in project root
#   cat > .sops.yaml << EOF
#   creation_rules:
#     - path_regex: .*-secrets-.*\.yaml$
#       age: >-
#         age1xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
#   EOF
#
# NEVER commit unencrypted secrets to version control!
# =============================================================================

secrets:
  method: sops

  data:
    # =========================================================================
    # PostgreSQL Secrets
    # =========================================================================
    postgresql:
      # Root password for postgres superuser
      # Generate with: openssl rand -base64 32
      rootPassword: "CHANGE_ME_postgres_root_password_here"

      # Application user password
      # Generate with: openssl rand -base64 32
      userPassword: "CHANGE_ME_postgres_user_password_here"

      # Full database URL (optional - auto-generated if empty)
      # Format: postgresql://username:password@host:port/database
      databaseUrl: ""

    # =========================================================================
    # MongoDB Secrets
    # =========================================================================
    mongodb:
      # Root/admin password
      # Generate with: openssl rand -base64 32
      rootPassword: "CHANGE_ME_mongodb_root_password_here"

      # Application user password
      # Generate with: openssl rand -base64 32
      userPassword: "CHANGE_ME_mongodb_user_password_here"

      # Full database URL (optional - auto-generated if empty)
      # Format: mongodb://username:password@host:port/database
      databaseUrl: ""

    # =========================================================================
    # RabbitMQ Secrets
    # =========================================================================
    rabbitmq:
      # RabbitMQ username
      username: "cptm8user"

      # RabbitMQ password
      # Generate with: openssl rand -base64 32
      password: "CHANGE_ME_rabbitmq_password_here"

      # Full AMQP URL (optional - auto-generated if empty)
      # Format: amqp://username:password@host:port/
      url: ""

    # =========================================================================
    # OpenSearch Secrets
    # =========================================================================
    opensearch:
      # Admin password for OpenSearch
      # Generate with: openssl rand -base64 32
      # Must meet complexity requirements: uppercase, lowercase, number, special char
      adminPassword: "CHANGE_ME_OpenSearch_Admin_123!"

    # =========================================================================
    # Application Secrets (NextAuth/AuthJS)
    # =========================================================================
    application:
      # NextAuth secret - used for JWT signing
      # Generate with: openssl rand -base64 64
      # MUST be at least 32 characters
      authSecret: "CHANGE_ME_generate_with_openssl_rand_base64_64_minimum_32_chars"

    # =========================================================================
    # SMTP Secrets (AWS SES)
    # =========================================================================
    smtp:
      # AWS SES SMTP username
      # Get from AWS SES console -> SMTP Settings -> Create SMTP credentials
      username: "AKIAXXXXXXXXXXXXXXXX"

      # AWS SES SMTP password
      # Get from AWS SES console -> SMTP Settings -> Create SMTP credentials
      password: "CHANGE_ME_ses_smtp_password_here"

    # =========================================================================
    # AWS S3 Secrets (Report Storage)
    # =========================================================================
    aws:
      # S3 access key for report bucket
      # Create IAM user with S3 access or use IAM role
      s3AccessKey: "AKIAXXXXXXXXXXXXXXXX"

      # S3 secret key
      s3SecretKey: "CHANGE_ME_s3_secret_key_here"

      # ECR access key ID (for pulling images)
      # Can use same as S3 or separate IAM user
      ecrAccessKeyId: "AKIAXXXXXXXXXXXXXXXX"

      # ECR secret access key
      ecrSecretAccessKey: "CHANGE_ME_ecr_secret_key_here"

    # =========================================================================
    # Google OAuth Secrets
    # =========================================================================
    google:
      # Google OAuth Client ID
      # Get from Google Cloud Console -> APIs & Services -> Credentials
      clientId: "123456789012-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx.apps.googleusercontent.com"

      # Google OAuth Client Secret
      clientSecret: "GOCSPX-XXXXXXXXXXXXXXXXXXXXXXXX"

# =============================================================================
# QUICK REFERENCE - Generate Secure Passwords
# =============================================================================
#
# Generate random password (32 chars):
#   openssl rand -base64 32
#
# Generate random password (64 chars, for authSecret):
#   openssl rand -base64 64
#
# Generate UUID:
#   uuidgen
#
# =============================================================================
# AWS CLI Commands for Creating IAM Credentials
# =============================================================================
#
# Create ECR access user:
#   aws iam create-user --user-name cptm8-ecr-staging
#   aws iam attach-user-policy --user-name cptm8-ecr-staging \
#     --policy-arn arn:aws:iam::aws:policy/AmazonEC2ContainerRegistryReadOnly
#   aws iam create-access-key --user-name cptm8-ecr-staging
#
# Create S3 access user:
#   aws iam create-user --user-name cptm8-s3-staging
#   aws iam put-user-policy --user-name cptm8-s3-staging \
#     --policy-name S3ReportAccess \
#     --policy-document file://s3-policy.json
#   aws iam create-access-key --user-name cptm8-s3-staging
#
# =============================================================================