# =============================================================================
# CPTM8 Helm Chart - Azure Staging Secrets
# =============================================================================
# This file contains sensitive values for Azure AKS staging deployment.
#
# INSTRUCTIONS:
#   1. Copy this file: cp values-secrets-staging-azure.yaml.example values-secrets-staging-azure.yaml
#   2. Fill in all the placeholder values with actual secrets
#   3. Encrypt with SOPS: sops -e -i values-secrets-staging-azure.yaml
#   4. Use with Helm: helm install cptm8 helm/cptm8 -f values-staging-azure.yaml -f <(sops -d values-secrets-staging-azure.yaml)
#
# SOPS SETUP (first time):
#   # Generate age key
#   age-keygen -o ~/.sops/age-key.txt
#
#   # Create .sops.yaml in project root
#   cat > .sops.yaml << EOF
#   creation_rules:
#     - path_regex: .*-secrets-.*\.yaml$
#       age: >-
#         age1xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
#   EOF
#
# ALTERNATIVE: Azure Key Vault with External Secrets Operator
#   See: https://external-secrets.io/latest/provider/azure-key-vault/
#
# NEVER commit unencrypted secrets to version control!
# =============================================================================

secrets:
  method: sops

  data:
    # =========================================================================
    # PostgreSQL Secrets
    # =========================================================================
    postgresql:
      # Root password for postgres superuser
      # Generate with: openssl rand -base64 32
      rootPassword: "CHANGE_ME_postgres_root_password_here"

      # Application user password
      # Generate with: openssl rand -base64 32
      userPassword: "CHANGE_ME_postgres_user_password_here"

      # Full database URL (optional - auto-generated if empty)
      # Format: postgresql://username:password@host:port/database
      databaseUrl: ""

    # =========================================================================
    # MongoDB Secrets
    # =========================================================================
    mongodb:
      # Root/admin password
      # Generate with: openssl rand -base64 32
      rootPassword: "CHANGE_ME_mongodb_root_password_here"

      # Application user password
      # Generate with: openssl rand -base64 32
      userPassword: "CHANGE_ME_mongodb_user_password_here"

      # Full database URL (optional - auto-generated if empty)
      # Format: mongodb://username:password@host:port/database
      databaseUrl: ""

    # =========================================================================
    # RabbitMQ Secrets
    # =========================================================================
    rabbitmq:
      # RabbitMQ username
      username: "cptm8user"

      # RabbitMQ password
      # Generate with: openssl rand -base64 32
      password: "CHANGE_ME_rabbitmq_password_here"

      # Full AMQP URL (optional - auto-generated if empty)
      # Format: amqp://username:password@host:port/
      url: ""

    # =========================================================================
    # OpenSearch Secrets
    # =========================================================================
    opensearch:
      # Admin password for OpenSearch
      # Generate with: openssl rand -base64 32
      # Must meet complexity requirements: uppercase, lowercase, number, special char
      adminPassword: "CHANGE_ME_OpenSearch_Admin_123!"

    # =========================================================================
    # Application Secrets (NextAuth/AuthJS)
    # =========================================================================
    application:
      # NextAuth secret - used for JWT signing
      # Generate with: openssl rand -base64 64
      # MUST be at least 32 characters
      authSecret: "CHANGE_ME_generate_with_openssl_rand_base64_64_minimum_32_chars"

    # =========================================================================
    # SMTP Secrets (SendGrid or Azure Communication Services)
    # =========================================================================
    smtp:
      # SendGrid API key as username (or Azure Communication Services)
      # For SendGrid: use "apikey" as username
      username: "apikey"

      # SendGrid API key (starts with SG.)
      # Get from SendGrid console -> Settings -> API Keys
      password: "SG.XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX"

    # =========================================================================
    # Azure Storage Secrets (Report Storage)
    # =========================================================================
    azure:
      # Azure Storage Account name
      storageAccountName: "cptm8reports"

      # Azure Storage Account key
      # Get from Azure Portal -> Storage Account -> Access keys
      storageAccountKey: "CHANGE_ME_azure_storage_key_base64_encoded_here=="

      # Azure ACR Service Principal (if not using managed identity)
      # Only needed if acrTokenRefresher is enabled without managed identity
      acrClientId: "xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx"
      acrClientSecret: "CHANGE_ME_acr_client_secret_here"
      acrTenantId: "xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx"

    # =========================================================================
    # AWS S3 Secrets (Optional - Cross-cloud report storage)
    # =========================================================================
    # Only needed if using AWS S3 from Azure for report storage
    aws:
      s3AccessKey: ""
      s3SecretKey: ""
      # Not needed for Azure
      ecrAccessKeyId: ""
      ecrSecretAccessKey: ""

    # =========================================================================
    # Google OAuth Secrets
    # =========================================================================
    google:
      # Google OAuth Client ID
      # Get from Google Cloud Console -> APIs & Services -> Credentials
      clientId: "123456789012-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx.apps.googleusercontent.com"

      # Google OAuth Client Secret
      clientSecret: "GOCSPX-XXXXXXXXXXXXXXXXXXXXXXXX"

# =============================================================================
# QUICK REFERENCE - Generate Secure Passwords
# =============================================================================
#
# Generate random password (32 chars):
#   openssl rand -base64 32
#
# Generate random password (64 chars, for authSecret):
#   openssl rand -base64 64
#
# Generate UUID:
#   uuidgen
#
# =============================================================================
# Azure CLI Commands for Creating Credentials
# =============================================================================
#
# Create Service Principal for ACR:
#   az ad sp create-for-rbac --name cptm8-acr-staging \
#     --scopes /subscriptions/{sub-id}/resourceGroups/{rg}/providers/Microsoft.ContainerRegistry/registries/{acr-name} \
#     --role acrpull
#
# Get Storage Account Key:
#   az storage account keys list \
#     --account-name cptm8reports \
#     --resource-group cptm8-staging-rg \
#     --query "[0].value" -o tsv
#
# Create Azure Key Vault Secret (alternative to SOPS):
#   az keyvault secret set --vault-name cptm8-staging-kv \
#     --name postgresql-root-password \
#     --value "$(openssl rand -base64 32)"
#
# =============================================================================
# Using Managed Identity (Recommended for AKS)
# =============================================================================
#
# If using AKS with managed identity, you can skip ACR credentials:
#   1. Enable managed identity on AKS cluster
#   2. Grant AcrPull role to the managed identity:
#      az role assignment create \
#        --assignee <managed-identity-client-id> \
#        --role acrpull \
#        --scope /subscriptions/{sub}/resourceGroups/{rg}/providers/Microsoft.ContainerRegistry/registries/{acr}
#   3. Set cronjobs.acrTokenRefresher.enabled=false in values
#
# =============================================================================